# Your email login (SMTP)
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password-or-app-password

# SMTP server (Gmail defaults shown)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Where enquiries are delivered (can be the same as SMTP_USER)
CONTACT_TO_EMAIL=info@raepathways.com.au

# Optional: sender address (defaults to SMTP_USER)
CONTACT_FROM_EMAIL=your-email@gmail.com
